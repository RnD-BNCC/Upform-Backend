generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Event {
  id              String     @id @default(uuid())
  name            String     @default("")
  description     String     @default("")
  status          String     @default("draft")
  color           String     @default("#0054a5")
  theme           String     @default("light")
  image           String?
  spreadsheetId    String?
  spreadsheetUrl   String?
  spreadsheetToken String?
  sections         Section[]
  responses       Response[]
  responseProgresses ResponseProgress[]
  emailComposerDraft EmailComposerDraft?
  emailBlasts     EmailBlast[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Section {
  id          String   @id @default(uuid())
  title       String   @default("")
  description String   @default("")
  order       Int      @default(0)
  fields      Json     @default("[]")
  settings    Json     @default("{}")
  pageType    String   @default("page")
  logicX      Float?
  logicY      Float?
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Response {
  id                  String   @id @default(uuid())
  answers             Json     @default("{}")
  respondentUuid      String?
  startedAt           DateTime?
  completedAt         DateTime?
  updatedAt           DateTime @default(now()) @updatedAt
  deviceType          String?
  userAgent           String?
  sectionHistory      Json     @default("[]")
  currentSectionId    String?
  currentSectionIndex Int?
  progressPercent     Float?
  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedAt         DateTime @default(now())
}

model ResponseProgress {
  id                  String   @id @default(uuid())
  answers             Json     @default("{}")
  otherTexts          Json     @default("{}")
  respondentUuid      String?
  startedAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deviceType          String?
  userAgent           String?
  sectionHistory      Json     @default("[]")
  currentSectionId    String?
  currentSectionIndex Int?
  progressPercent     Float?
  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([eventId, respondentUuid])
}

model Poll {
  id           String      @id @default(uuid())
  title        String      @default("")
  code         String      @unique
  status       String      @default("waiting")
  currentSlide Int         @default(0)
  settings     Json        @default("{}")
  slides       PollSlide[]
  questions    Question[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Question {
  id          String         @id @default(uuid())
  pollId      String
  text        String         @db.VarChar(200)
  authorName  String
  authorId    String?
  likeCount   Int            @default(0)
  createdAt   DateTime       @default(now())

  likes       QuestionLike[]
  poll        Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model QuestionLike {
  id         String   @id @default(uuid())
  questionId String
  userId     String
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
}

model PollSlide {
  id        String     @id @default(uuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  order     Int        @default(0)
  type      String
  question  String     @default("")
  options   Json       @default("[]")
  settings  Json       @default("{}")
  locked    Boolean    @default(false)
  votes     PollVote[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PollVote {
  id            String    @id @default(uuid())
  slideId       String
  slide         PollSlide @relation(fields: [slideId], references: [id], onDelete: Cascade)
  participantId String
  value         Json
  isAnswered    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@unique([slideId, participantId])
}

model EmailBlast {
  id          String     @id @default(uuid())
  eventId     String?
  event       Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subject     String
  html        String
  recipients  String[]
  status      String     @default("queued")
  sentCount   Int        @default(0)
  failedCount Int        @default(0)
  totalCount  Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        EmailLog[]
}

model EmailComposerDraft {
  id                    String   @id @default(uuid())
  eventId               String   @unique
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subject               String   @default("")
  emailStyle            String   @default("formatted")
  emailThemeValue       String?
  blocks                Json     @default("[]")
  recipientMode         String   @default("manual")
  manualRecipients      String[] @default([])
  selectedEmailFieldIds String[] @default([])
  excludedRecipients    String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model EmailLog {
  id        String     @id @default(uuid())
  blastId   String
  blast     EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)
  recipient String
  status    String
  error     String?
  attempt   Int        @default(1)
  sentAt    DateTime?
  createdAt DateTime   @default(now())

  @@unique([blastId, recipient])
}
